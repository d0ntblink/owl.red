$ORIGIN owl.red.
$TTL 300
@ IN SOA ns1.owl.red. hostmaster.owl.red. (
  2026051202 ; serial (update on every record change)
  3600       ; refresh
  600        ; retry
  1209600    ; expire
  300        ; minimum
)
@ IN NS ns1.owl.red.

ns1             IN A 10.0.10.30
dns             IN A 10.0.10.201
rancher         IN A 10.0.10.201
home            IN A 10.0.10.201
traefik         IN A 10.0.10.201
edge            IN A 10.0.10.1
switch          IN A 10.0.10.2
edge.pve        IN A 10.0.10.3
storage.pve     IN A 10.0.10.4
nas             IN A 10.0.10.5
ipmi.storage    IN A 10.0.10.6
pdu             IN A 10.0.10.7
cp1.pve         IN A 10.0.10.11
cp2.pve         IN A 10.0.10.12
cp3.pve         IN A 10.0.10.13
worker1.pve     IN A 10.0.10.14
cp1.k8s         IN A 10.0.10.21
cp2.k8s         IN A 10.0.10.22
cp3.k8s         IN A 10.0.10.23
worker1.k8s     IN A 10.0.10.24
pdm             IN A 10.0.10.201
pdm-direct      IN A 10.0.10.31
pbs             IN A 10.0.10.33
ap              IN A 10.0.10.40
technitium      IN A 10.0.10.201
